# Maintainer: Nick Schuch <nick.schuch@skpr.io>

pkgname=php8.5-compass
_pkgreal=compass
pkgver=0.0.6
pkgrel=1
provides="php-compass=8.5"
pkgdesc="Compass - Probes for instrumenting PHP applications"
url="https://github.com/skpr/compass-extension"
arch="all"
license="PHP-3"

depends="php8.5-common>=8.5.0 php8.5-common<8.6.0"
makedepends="php8.5-dev>=8.5.0 php8.5-dev<8.6.0 autoconf alpine-sdk clang clang-dev"

source="php-compass-$pkgver.tar.gz::https://github.com/skpr/compass-extension/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/compass-extension-$pkgver"

prepare() {
    default_prepare || return 1
}

build() {
    cd "$builddir"
    curl https://mise.run | sh
    export MISE_YES=1
    ~/.local/bin/mise build
}

package() {
    mkdir -p "$pkgdir"/etc/php/conf.d
    mkdir -p "$pkgdir"/usr/lib/php/modules
    cp "$builddir/00_compass.ini" "$pkgdir/etc/php/conf.d/00_compass.ini"
    cp "$builddir/target/release/libcompass_extension.so" "$pkgdir/usr/lib/php/modules/compass.so"
}

sha512sums="
75b8ac2491d60736ab8c03fc88d0dfbb42f18deae1f425b9c2eb3047783a362d8260720779b6ca86c5ea5777372b36f5cae8713641568b35fdf424028ecc5cee  compass-extension-0.0.6.tar.gz
"
